# DealScanner — copy to .env (chmod 600) and fill in. Secrets never go in git.

# Scraping / scoring / enrichment
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=

# Mail — Resend is primary; Gmail app password is the fallback sender
RESEND_API_KEY=
MAIL_FROM=DealScanner <deals@example.com>
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=

# Auth: magic-link signing secret (generate: openssl rand -hex 32)
DS_SECRET=

# Operators allowed to sign in (comma-separated)
ALLOW_LIST=you@example.com

# Daily digest: email:thesis pairs, comma-separated.
# e.g. DIGEST_RECIPIENTS=alice@x.com:water,bob@y.com:healthcare
DIGEST_RECIPIENTS=you@example.com:healthcare
DEFAULT_THESIS=healthcare

# Dead-man switch: create a check at healthchecks.io, paste its ping URL
HEALTHCHECK_URL=
